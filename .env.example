# ─────────────────────────────────────────────────────────────────────────────
# NexLink Server — Environment Configuration
# Copy to .env and fill in production values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (asyncpg for async, psycopg2 for Alembic offline)
NEXLINK_DATABASE_URL=postgresql+asyncpg://nexlink:nexlink@localhost:5432/nexlink
NEXLINK_DATABASE_POOL_SIZE=20
NEXLINK_DATABASE_MAX_OVERFLOW=10
NEXLINK_DATABASE_POOL_TIMEOUT=30

# ── Server ────────────────────────────────────────────────────────────────────
NEXLINK_HOST=0.0.0.0
NEXLINK_PORT=9000
NEXLINK_DEBUG=false
NEXLINK_WORKERS=1

# ── JWT ───────────────────────────────────────────────────────────────────────
# CRITICAL: Change this to a cryptographically random 64+ character string in production
# Generate: python -c "import secrets; print(secrets.token_hex(64))"
NEXLINK_JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_SECRETS_TOKEN_HEX_64
NEXLINK_JWT_ALGORITHM=HS256
NEXLINK_JWT_ACCESS_EXPIRE_MINUTES=60
NEXLINK_JWT_REFRESH_EXPIRE_DAYS=30

# ── Heartbeat ─────────────────────────────────────────────────────────────────
# Seconds before a device is marked OFFLINE if no heartbeat received
NEXLINK_HEARTBEAT_TIMEOUT_SECONDS=60
# How often the server checks for stale heartbeats (seconds)
NEXLINK_HEARTBEAT_CHECK_INTERVAL_SECONDS=15

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list. Use "*" for dev, restrict for production.
NEXLINK_CORS_ORIGINS=*

# ── Logging ───────────────────────────────────────────────────────────────────
NEXLINK_LOG_LEVEL=INFO
# json = structured (production) | console = colourised (development)
NEXLINK_LOG_FORMAT=json
NEXLINK_LOG_DIR=logs

# ── Event Bus ─────────────────────────────────────────────────────────────────
NEXLINK_EVENT_BUS_MAX_QUEUE_SIZE=10000

# ── API Keys ──────────────────────────────────────────────────────────────────
# Master admin key for initial setup. Rotate immediately after first use.
NEXLINK_ADMIN_API_KEY=CHANGE_ME_ADMIN_KEY
